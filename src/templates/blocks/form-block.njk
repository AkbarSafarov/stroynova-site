<!-- ОСТАЛИСЬ ВОПРОСЫ -->
<section class="section section--contact-cta section--contact-cta-inner" aria-labelledby="contact-cta-heading">
    <div class="container">
        <div class="contact-cta">
            <img class="contact-cta__bg" src="/assets/images/form-block.jpg" alt="" aria-hidden="true" loading="lazy" />
            <div class="contact-cta__layout">
                <div class="contact-cta__left">
                    <h2 id="contact-cta-heading" class="contact-cta__title">Приглашаем                         в демо-квартиру</h2>
                    <p class="contact-cta__subtitle">Оставьте ваши контакты и мы свяжемся с вами</p>
                </div>

                <form class="contact-cta__form" novalidate>
                    <div class="contact-cta__inputs">
                        <div class="contact-cta__field">
                            <div class="contact-cta__input-wrap">
                                <label class="contact-cta__label" for="cta-name">Ваше имя</label>
                                <input class="contact-cta__input" type="text" id="cta-name" name="name" placeholder="Имя" autocomplete="given-name" />
                            </div>
                        </div>
                        <div class="contact-cta__field">
                            <div class="contact-cta__input-wrap">
                                <label class="contact-cta__label" for="cta-phone">Номер телефона</label>
                                <input class="contact-cta__input" type="tel" id="cta-phone" name="phone" placeholder="+7(___)-___-__-__" autocomplete="tel" />
                            </div>
                        </div>
                    </div>
                    <div class="contact-cta__row">
                        <label class="contact-cta__checkbox-wrap">
                            <input class="contact-cta__checkbox" type="checkbox" name="consent" required />
                            <i></i>
                            <span class="contact-cta__checkbox-text">
                                Я согласен условиями предоставления услуг и обработкой моих персональных данных при нажатии «Отправить»
                            </span>
                        </label>
                        <div class="contact-cta__socials">
                            <a href="https://t.me/stroynova" class="contact-cta__social-btn" aria-label="Написать в Telegram" target="_blank" rel="noopener noreferrer">
                                <svg width="30" height="30" aria-hidden="true" focusable="false"><use href="#telegram-icon" /></svg>
                            </a>
                            <a href="https://ok.ru/stroynova" class="contact-cta__social-btn" aria-label="Написать в Одноклассники" target="_blank" rel="noopener noreferrer">
                                <svg width="24" height="24" aria-hidden="true" focusable="false"><use href="#mx-icon" /></svg>
                            </a>
                        </div>
                        <button class="btn__button btn_orange contact-cta__submit" type="submit">Отправить</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</section>
