<section class="section section--mortgage" aria-labelledby="apt-mortgage-heading">
    <div class="container">
        <div class="container__inner">
            <div class="mortgage__bg" aria-hidden="true">
                <img src="/assets/images/bg.jpg" alt="" aria-hidden="true" />
            </div>
            <div class="mortgage__top">
                <h2 id="apt-mortgage-heading" class="mortgage__title">Ипотечный калькулятор</h2>
                <div class="mortgage__row">
                    <div class="mortgage__inputs">
                        <div class="mort-slider">
                            <div class="mort-slider__top">
                                <label class="mort-slider__label" for="apt-mort-price">Стоимость жилья <strong>₽</strong></label>
                            </div>
                            <input class="mort-slider__val" type="text" inputmode="numeric" id="apt-mort-price-val" value="9 200 400" />
                            <input class="mort-slider__range" type="range" id="apt-mort-price" min="1000000" max="50000000" value="9200400" step="100000" />
                        </div>
                        <div class="mort-slider">
                            <label class="mort-slider__label" for="apt-mort-term">Срок, лет</label>
                            <input class="mort-slider__val" type="text" inputmode="numeric" id="apt-mort-term-val" value="15" />
                            <input class="mort-slider__range" type="range" id="apt-mort-term" min="1" max="30" value="15" step="1" />
                        </div>
                        <div class="mort-slider">
                            <div class="mort-slider__top">
                                <label class="mort-slider__label" for="apt-mort-down">Первоначальный взнос <stron>₽</stron></label>
                                <output class="mort-slider__pct" id="apt-mort-down-pct">25%</output>
                            </div>
                            <input class="mort-slider__val" type="text" inputmode="numeric" id="apt-mort-down-val" value="2 300 100" />
                            <input class="mort-slider__range" type="range" id="apt-mort-down" min="10" max="90" value="25" step="1" />
                        </div>
                        <div class="mort-slider">
                            <label class="mort-slider__label" for="apt-mort-rate">Ставка <strong>%</strong></label>
                            <input class="mort-slider__val" type="text" inputmode="numeric" id="apt-mort-rate-val" value="15" />
                            <input class="mort-slider__range" type="range" id="apt-mort-rate" min="1" max="100" value="15" step="0.5" />
                        </div>
                    </div>
                    <div class="mortgage__result-card">
                        <div class="mortgage__result-card-top">
                            <div class="mortgage__result-card-inner">
                                <div class="mortgage__donut-wrap">
                                    <div class="mortgage__donut">
                                        <svg class="donut-svg" viewBox="0 0 172 172" fill="none" aria-hidden="true">
                                            <circle class="donut-svg__track" cx="86" cy="86" r="75" />
                                            <circle class="donut-svg__credit" id="apt-donut-credit-arc" cx="86" cy="86" r="75" transform="rotate(-90 86 86)" />
                                        </svg>
                                        <div class="donut-center" aria-hidden="true">₽</div>
                                    </div>
                                </div>
                                <div class="donut-legend">
                                    <div class="donut-legend__item">
                                        <span class="donut-legend__dot donut-legend__dot--credit"></span>
                                        <div>
                                            <p class="donut-legend__name">Кредит</p>
                                            <p class="donut-legend__val" id="apt-legend-credit">—</p>
                                        </div>
                                    </div>
                                    <div class="donut-legend__item">
                                        <span class="donut-legend__dot donut-legend__dot--interest"></span>
                                        <div>
                                            <p class="donut-legend__name">Проценты</p>
                                            <p class="donut-legend__val" id="apt-legend-interest">—</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="mortgage__summary">
                                    <div class="mortgage__payment">
                                        <p class="mortgage__payment-label">Ежемесячный платёж</p>
                                        <p class="mortgage__payment-val" id="apt-mort-monthly">—</p>
                                    </div>
                                    <div class="mortgage__income">
                                        <p class="mortgage__income-label">Необходимый доход</p>
                                        <p class="mortgage__income-val" id="apt-mort-income">—</p>
                                    </div>
                                </div>
                            </div>
                            <div class="mortgage__banks">
                                <p class="mortgage__banks-label">Банки партнёры:</p>
                                <div class="mortgage__banks-logos">
                                    <span class="bank-name bank-name--sovkom">
                                        <img src="/assets/images/bank1.svg" alt="" aria-hidden="true">
                                    </span>
                                    <span class="bank-name bank-name--vtb"><img src="/assets/images/bank2.svg" alt="" aria-hidden="true"></span>
                                    <span class="bank-name bank-name--sber"><img src="/assets/images/bank3.svg" alt="" aria-hidden="true"></span>
                                    <span class="bank-name bank-name--gazprom"><img src="/assets/images/bank4.svg" alt="" aria-hidden="true"></span>
                                    <span class="bank-name bank-name--rshb"><img src="/assets/images/bank5.svg" alt="" aria-hidden="true"></span>
                                </div>
                            </div>
                        </div>
                        <div class="mortgage__programs" role="group" aria-label="Программы ипотеки">
                            <button class="mort-tab mort-tab--active" type="button" data-rate="15">Базовая <span>от 26%</span></button>
                            <button class="mort-tab" type="button" data-rate="6">Семейная <span>от 6%</span></button>
                            <button class="mort-tab" type="button" data-rate="8">Ипотека для IT <span>от 8%</span></button>
                        </div>
                    </div>
                </div>
                <div class="mortgage__banks mortgage__banks-mob">
                    <p class="mortgage__banks-label">Банки партнёры:</p>
                    <div class="mortgage__banks-logos">
                                    <span class="bank-name bank-name--sovkom">
                                        <img src="/assets/images/bank1.svg" alt="" aria-hidden="true">
                                    </span>
                        <span class="bank-name bank-name--vtb"><img src="/assets/images/bank2.svg" alt="" aria-hidden="true"></span>
                        <span class="bank-name bank-name--sber"><img src="/assets/images/bank3.svg" alt="" aria-hidden="true"></span>
                        <span class="bank-name bank-name--gazprom"><img src="/assets/images/bank4.svg" alt="" aria-hidden="true"></span>
                        <span class="bank-name bank-name--rshb"><img src="/assets/images/bank5.svg" alt="" aria-hidden="true"></span>
                    </div>
                </div>
                <div class="mortgage__programs mortgage__programs-mob" role="group" aria-label="Программы ипотеки">
                    <button class="mort-tab mort-tab--active" type="button" data-rate="15">Базовая <span>от 26%</span></button>
                    <button class="mort-tab" type="button" data-rate="6">Семейная <span>от 6%</span></button>
                    <button class="mort-tab" type="button" data-rate="8">Ипотека для IT <span>от 8%</span></button>
                </div>
            </div>
            <div class="mortgage__bottom">
                <div class="mortgage__bottom-left">
                    <p class="mortgage__bottom-text">Вы можете подать заявку на одобрение ипотеки сразу во все банки-партнёры</p>
                    <p class="mortgage__bottom-big" aria-hidden="true">ИПОТЕКА</p>
                </div>
                <div class="mortgage__form">
                    <div class="contact-cta__field">
                        <div class="contact-cta__input-wrap">
                            <label class="contact-cta__label" for="cta-phone">Номер телефона</label>
                            <input class="contact-cta__input" type="tel" id="cta-phone" name="phone" placeholder="+7(___)-___-__-__" autocomplete="tel" />
                        </div>
                    </div>
                    <button class="btn__button btn_orange mortgage__submit" type="button">Получить предложение</button>
                    <label class="contact-cta__checkbox-wrap">
                        <input class="contact-cta__checkbox" type="checkbox" name="consent" required />
                        <i></i>
                        <span class="contact-cta__checkbox-text">
                                Я согласен условиями предоставления услуг и обработкой моих персональных данных при нажатии “Заказать звонок”
                            </span>
                    </label>
                </div>
                <p class="mortgage__bottom-big mortgage__bottom-big-mob" aria-hidden="true">ИПОТЕКА</p>
            </div>
        </div>
    </div>
</section>
