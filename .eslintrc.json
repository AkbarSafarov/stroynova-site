{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "no-global-assign": "error",
    "no-implicit-globals": "error"
  }
}
